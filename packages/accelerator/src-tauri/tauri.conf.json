{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Aztec Accelerator",
  "version": "1.0.7-rc.1",
  "identifier": "dev.aztec.accelerator",
  "build": {
    "frontendDist": "./frontend",
    "beforeDevCommand": "bun run frontend:build",
    "beforeBuildCommand": "bun run frontend:build"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self'; connect-src ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none'; frame-src 'none'; child-src 'none'; worker-src 'none'",
      "capabilities": ["authorize", "settings", "update-prompt"]
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://aztec-accelerator.dev/releases/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzNzEzODFFMEEzMzU2QTgKUldTb1ZqTUtIamh4czNrcWR3QVZiUmIwdyttSzg5OUhtZXJobURnY05KL2pCZWMydDFPcWkvWFAK",
      "windows": {
        "installMode": "quiet"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "externalBin": [
      "binaries/bb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "main.desktop"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
