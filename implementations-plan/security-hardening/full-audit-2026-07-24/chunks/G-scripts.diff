+function streamResp(bytes: Uint8Array, o: { status?: number; contentLength?: string | null } = {}) {
+  const status = o.status ?? 200;
+  return {
+    ok: status >= 200 && status < 300,
+    status,
+    statusText: "s",
+    headers: {
+      get: (k: string) =>
