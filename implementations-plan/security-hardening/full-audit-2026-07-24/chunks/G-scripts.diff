+  const asset = `barretenberg-${currentPlatform()}.tar.gz`;
+  const digest = sha256Hex(tarball);
+  routeFetch((url) => {
+    if (url.includes("api.github.com")) {
+      return jsonResp(200, { assets: [{ name: asset, digest: `sha256:${digest}` }] });
+    }
+    return streamResp(tarball);
+  });
