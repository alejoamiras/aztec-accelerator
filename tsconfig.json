{
  "compilerOptions": {
    "target": "ESNext",
    "moduleResolution": "NodeNext",
    "module": "NodeNext",

    // Bun types for bun:test, Bun.spawn, etc. (TS6+ requires explicit @types)
    "types": ["bun"],

    // compatibility
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,

    // lib
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // strictness
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true
  }
}
