{
  "private": true,
  "license": "AGPL-3.0-only",
  "workspaces": [
    "packages/sdk",
    "packages/accelerator",
    "packages/playground",
    "packages/landing"
  ],
  "scripts": {
    "aztec:check": "bun scripts/check-aztec-update.ts",
    "aztec:update": "bun scripts/update-aztec-version.ts",
    "bb:download": "bun scripts/download-bb.ts",
    "bb:list": "bun scripts/download-bb.ts --list",
    "format": "biome format --write .",
    "lint": "biome check . && bun run lint:pkg && bun run lint:rust",
    "lint:actions": "actionlint",
    "lint:fix": "biome check --write . && cd packages/accelerator/src-tauri && cargo fmt",
    "lint:pkg": "sort-package-json --check package.json packages/*/package.json",
    "lint:rust": "cd packages/accelerator/src-tauri && cargo fmt --check",
    "lint:shell": "shellcheck scripts/*.sh",
    "lint:tofu": "cd infra/tofu && tofu fmt -check -diff .",
    "playground": "bun run --cwd packages/playground dev",
    "prepare": "husky",
    "sdk:build": "bun run --cwd packages/sdk build",
    "test": "bun run lint && bun run test:typecheck && bun run test:unit",
    "test:all": "bun run test && bun run test:e2e",
    "test:e2e": "bun run --cwd packages/sdk test:e2e",
    "test:typecheck": "bun run --cwd packages/sdk test:lint",
    "test:unit": "bun run --cwd packages/sdk test:unit && bun run --cwd packages/playground test:unit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    ".github/workflows/*.yml": [
      "actionlint"
    ],
    "*.rs": [
      "rustfmt --edition 2021"
    ],
    "*.sh": [
      "shellcheck"
    ],
    "infra/tofu/*.tf": [
      "tofu fmt"
    ],
    "**/package.json": [
      "sort-package-json"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "bun-types": "^1.3.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "sort-package-json": "^3.6.1",
    "typescript": "^5.9.3"
  }
}
